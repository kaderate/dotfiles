# Unix
alias ll='ls -alh'
alias ln='ln -v'
alias mkdir='mkdir -p'
alias e='$EDITOR'
alias ww='watch -n1'
alias myip='dig +short myip.opendns.com @resolver1.opendns.com'
function mkcd() { mkdir $1 && cd $1 }
alias v='nvim'

# Net
alias tcpdumpen='sudo tcpdump -qtni en0'
# dnstope en0

# Doc (pandoc)
pdf() {
  pandoc -o $1.pdf $1
  open $1.pdf
}

# Bundler
alias be='bundle exec'

# Rails
alias rc='rails c'
alias rs='rails s'

# Git
alias gst='git status'
alias gd='git diff'
alias gdc='git diff --cached'
alias gci='git commit'
alias grh='git reset HEAD'
alias gs='git stash'
alias gsp='git stash pop'
alias ga='git add'
alias gco='git checkout'
alias gb='git branch'
alias gss='git stash'
alias gsp='git stash pop'
alias gl='git log --decorate --all'

# Docker
alias dc='docker compose'
alias dcp='docker compose ps'
alias dcu='docker compose up -d'
alias dcd='docker compose down'
alias dcl='docker compose logs -f'
alias dcr='docker compose run --rm'
alias dce='docker compose exec'
alias dcspec='docker compose run --rm -e RAILS_ENV=test app bundle exec rspec'
alias dcrails='docker compose exec app bundle exec rails'
alias dcb='docker compose exec web bundle'
alias dcbe='docker compose exec web bundle exec'
# Kubernetes
alias k='kubectl'

# Pretty print the path
alias path='echo $PATH | tr -s ":" "\n"'
